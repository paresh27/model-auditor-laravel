{
    "name": "paresh27/model-auditor-laravel",
    "description": "Laravel integration for paresh27/model-auditor — audit Eloquent model changes",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "audit", "eloquent"],
    "authors": [
        { "name": "Paresh", "email": "you@example.com" }
    ],
"require": {
    "php": "^8.3",
    "paresh27/model-auditor": "^1.0",
    "illuminate/database": "^11.0|^12.0",
    "illuminate/support": "^11.0|^12.0",
    "illuminate/contracts": "^11.0|^12.0"
},
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^4.7",
        "pestphp/pest-plugin-laravel": "^4.1",
        "laravel/pint": "^1.29",
        "phpstan/phpstan": "^2.2",
        "larastan/larastan": "^3.10"
    },
    "autoload": {
        "psr-4": {
            "Paresh27\\ModelAuditorLaravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Paresh27\\ModelAuditorLaravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Paresh27\\ModelAuditorLaravel\\ModelAuditorServiceProvider"
            ]
        }
    },
"scripts": {
    "test": "pest",
    "format": "pint",
    "analyse": "phpstan analyse"
},
    "minimum-stability": "stable",
    "prefer-stable": true,
"repositories": [
    { "type": "vcs", "url": "https://github.com/paresh27/model-auditor" }
],
"config": {
    "allow-plugins": {
        "pestphp/pest-plugin": true,
        "pestphp/pest-plugin-laravel": true
    },
    "policy": {
        "advisories": {
            "block": false
        },
        "abandoned": {
            "block": false
        }
    }
}
}
